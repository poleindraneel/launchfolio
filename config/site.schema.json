{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/poleindraneel/launchfolio/config/site.schema.json",
  "title": "launchfolio site config (window.SITE)",
  "description": "Contract for config/site.config.js. Agents and humans edit ONLY that file. Validate with `npm run check`.",
  "type": "object",
  "required": ["meta", "identity", "sections"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "url": { "type": "string" },
        "ogImage": { "type": "string" },
        "twitter": { "type": "string" },
        "lang": { "type": "string" }
      }
    },
    "theme": {
      "type": "object",
      "properties": {
        "ink": { "type": "string" }, "surface": { "type": "string" },
        "surfaceAlt": { "type": "string" }, "surfaceAlt2": { "type": "string" },
        "line": { "type": "string" }, "line2": { "type": "string" },
        "text": { "type": "string" }, "textDim": { "type": "string" }, "paper": { "type": "string" },
        "accentWarm": { "type": "string" }, "accentCool": { "type": "string" },
        "faviconLetter": { "type": "string" }, "faviconColor": { "type": "string" },
        "fonts": {
          "type": "object",
          "properties": {
            "display": { "type": "string" }, "body": { "type": "string" },
            "mono": { "type": "string" }, "script": { "type": "string" },
            "googleFontsHref": { "type": "string" }
          }
        }
      }
    },
    "identity": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "nameLines": { "type": "array", "items": { "type": "string" } },
        "wordmark": { "type": "string" },
        "secondaryScript": { "type": "string" },
        "eyebrow": { "type": "string" },
        "tagline": { "type": "string" },
        "location": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "chips": { "type": "array", "items": { "type": "string" } },
        "ctas": { "type": "array", "items": { "$ref": "#/$defs/cta" } },
        "now": { "type": "array", "items": { "type": "string" } }
      }
    },
    "social": {
      "type": "object",
      "properties": {
        "website": { "type": "string" }, "github": { "type": "string" },
        "linkedin": { "type": "string" }, "medium": { "type": "string" },
        "substack": { "type": "string" }, "twitter": { "type": "string" },
        "devto": { "type": "string" }
      }
    },
    "footer": {
      "type": "object",
      "properties": { "mark": { "type": "string" }, "note": { "type": "string" } }
    },
    "analytics": {
      "type": "object",
      "description": "Optional, privacy-friendly analytics. Off unless provider is set.",
      "properties": {
        "provider": { "enum": ["none", "plausible", "umami", "goatcounter"] },
        "respectDNT": { "type": "boolean" },
        "trackOutboundClicks": { "type": "boolean" },
        "domain": { "type": "string" },
        "websiteId": { "type": "string" },
        "endpoint": { "type": "string" },
        "scriptUrl": { "type": "string" }
      }
    },
    "sections": {
      "type": "object",
      "properties": {
        "about": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }, "navLabel": { "type": "string" }, "title": { "type": "string" },
            "lead": { "type": "string" },
            "pillars": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["title"],
                "properties": {
                  "icon": { "enum": ["build", "teach", "research", "ship", "spark", "pen", "mic", "code", "globe"] },
                  "title": { "type": "string" }, "text": { "type": "string" }
                }
              }
            }
          }
        },
        "experience": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }, "navLabel": { "type": "string" }, "title": { "type": "string" },
            "orgs": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["org", "roles"],
                "properties": {
                  "org": { "type": "string" }, "location": { "type": "string" },
                  "roles": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["title", "start"],
                      "properties": {
                        "title": { "type": "string" },
                        "start": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
                        "end": { "type": ["string", "null"], "pattern": "^\\d{4}-\\d{2}$" },
                        "text": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "research": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }, "navLabel": { "type": "string" }, "title": { "type": "string" },
            "program": { "type": "string" }, "school": { "type": "string" }, "text": { "type": "string" },
            "themes": { "type": "array", "items": { "type": "string" } },
            "education": {
              "type": "array",
              "items": { "type": "object", "properties": { "degree": { "type": "string" }, "school": { "type": "string" }, "period": { "type": "string" } } }
            },
            "certifications": { "type": "array", "items": { "type": "string" } },
            "languages": {
              "type": "array",
              "items": { "type": "object", "properties": { "name": { "type": "string" }, "level": { "type": "string" } } }
            },
            "skills": {
              "type": "array",
              "items": { "type": "object", "properties": { "group": { "type": "string" }, "items": { "type": "array", "items": { "type": "string" } } } }
            },
            "project": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" }, "eyebrow": { "type": "string" },
                "name": { "type": "string" }, "fullName": { "type": "string" }, "tagline": { "type": "string" },
                "highlights": { "type": "array", "items": { "type": "string" } },
                "repo": { "type": "string" }, "owner": { "type": "string" }, "repoName": { "type": "string" },
                "milestones": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["phase", "title", "status"],
                    "properties": {
                      "phase": { "type": "string" }, "title": { "type": "string" },
                      "status": { "enum": ["done", "active", "planned"] },
                      "due": { "type": ["string", "null"] }, "progress": { "type": ["string", "null"] },
                      "detail": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        },
        "writing": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }, "navLabel": { "type": "string" }, "title": { "type": "string" }, "intro": { "type": "string" },
            "tracks": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "label"],
                "properties": {
                  "id": { "type": "string" }, "label": { "type": "string" }, "labelScript": { "type": "boolean" },
                  "accent": { "enum": ["cool", "warm"] },
                  "seeAllUrl": { "type": "string" },
                  "sources": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["type"],
                      "properties": {
                        "type": { "enum": ["medium", "substack", "devto", "rss", "linkedin", "manual"] },
                        "handle": { "type": "string" }, "url": { "type": "string" }, "label": { "type": "string" }
                      }
                    }
                  },
                  "posts": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["title", "url"],
                      "properties": {
                        "title": { "type": "string" }, "date": { "type": "string" }, "source": { "type": "string" },
                        "excerpt": { "type": "string" }, "url": { "type": "string" }, "manual": { "type": "boolean" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "speaking": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }, "navLabel": { "type": "string" }, "title": { "type": "string" }, "intro": { "type": "string" },
            "featured": {
              "type": "object",
              "properties": {
                "title": { "type": "string" }, "venue": { "type": "string" }, "note": { "type": "string" },
                "tags": { "type": "array", "items": { "type": "string" } },
                "images": { "type": "array", "items": { "type": "object", "properties": { "src": { "type": "string" }, "alt": { "type": "string" } } } }
              }
            },
            "more": {
              "type": "array",
              "items": { "type": "object", "properties": { "title": { "type": "string" }, "venue": { "type": "string" }, "note": { "type": "string" } } }
            }
          }
        },
        "contact": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }, "navLabel": { "type": "string" },
            "eyebrow": { "type": "string" }, "title": { "type": "string" },
            "email": { "type": "string" }, "showSocials": { "type": "boolean" }
          }
        }
      }
    }
  },
  "$defs": {
    "cta": {
      "type": "object",
      "required": ["label"],
      "properties": {
        "label": { "type": "string" }, "href": { "type": "string" },
        "style": { "enum": ["solid", "ghost"] }
      }
    }
  }
}
